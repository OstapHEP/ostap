#!/usr/bin/env sh

# =============================================================================
# Safe argument check
# =============================================================================
LCG="${1:?Error: Specify LCG version (e.g., LCG_105)}"
PLATFORM="${2:?Error: Specify PLATFORM (e.g., x86_64-el9-gcc13-opt)}"

# =============================================================================
printf "=== TEST-WITH-LCG Environment Info ===\n"
printf "LCG      : %s\n" "${LCG}"
printf "PLATFORM : %s\n" "${PLATFORM}"
# =============================================================================

# =============================================================================
# Navigate into build directory safely
# =============================================================================
cd ./build || exit 1

LCG_SETUP_SCRIPT="/cvmfs/sft.cern.ch/lcg/views/${LCG}/${PLATFORM}/setup.sh"
OSTAP_SETUP_SCRIPT="./INSTALL/${LCG}/${PLATFORM}/thisostap.sh"

if [ -n "${LCG}" ] && [ -n "${PLATFORM}" ] && \
   [ -f "${LCG_SETUP_SCRIPT}" ] && [ -f "${OSTAP_SETUP_SCRIPT}" ]; then

    # =========================================================================
    printf "TEST-WITH-LCG: sourcing %s\n" "${LCG_SETUP_SCRIPT}"
    # shellcheck disable=SC1091
    . "${LCG_SETUP_SCRIPT}"
    # =========================================================================
    printf "TEST-WITH-LCG: sourcing %s\n" "${OSTAP_SETUP_SCRIPT}"
    # shellcheck disable=SC1091
    . "${OSTAP_SETUP_SCRIPT}"
    # =========================================================================

else

    # =========================================================================
    printf "(re)source .build-lcg\n"
    # shellcheck disable=SC1091
    . ../.aux/.build-lcg "${LCG}" "${PLATFORM}"
    # =========================================================================

fi

# =============================================================================
printf "=== TEST-WITH-LCG Environment Info ===\n"
printf "Python binary:  %s\n" "$(which python)"
printf "Python version: %s\n" "$(python --version 2>&1)"
# =============================================================================

# =============================================================================
# Check Python user-site directory
# =============================================================================
user_site=$(python -m site --user-site)
if [ -d "${user_site}" ]; then
    printf "TEST-WITH-LCG:      USER-SITE directory %s\n" "${user_site}"
    ls -la "${user_site}"
else
    printf "TEST-WITH-LCG:   no USER-SITE directory %s\n" "${user_site}"
fi

# =============================================================================
# List user-installed pip packages if pip is available
# =============================================================================
if command -v pip >/dev/null 2>&1; then
    python -m pip list --user || true
fi

# =============================================================================
# Recheck all dependencies
# =============================================================================
if command -v check-dependencies >/dev/null 2>&1; then
    COLUMNS=200 check-dependencies
fi

# =============================================================================
# Run tests
# =============================================================================
OSTAP_BATCH=True COLUMNS=200 ctest -j4 --output-on-failure --test-output-size-failed 5000000

# =============================================================================
#                                                                       The END
# =============================================================================

