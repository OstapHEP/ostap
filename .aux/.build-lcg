#!/usr/bin/env sh

LCG="${1:-dev3/latest}"
PLATFORM="${2:-x86_64-el9-clang22-opt}" 

prefix='<<OSTAP WITH LCG>>'
prefix_error='<<OSTAP WITH LCG ERROR>>'

# =========================================================================
# Portable Helper Functions
# =========================================================================

# Check if script is sourced in POSIX-compliant shells
is_sourced() {
    (return 0 2>/dev/null)
}

safe_exit() {
    exit_code="${1:-0}"
    if is_sourced; then
        return "$exit_code"
    else
        exit "$exit_code"
    fi
}

# Cross-platform canonical absolute path resolution (replaces GNU readlink -f / realpath -m)
get_canonical_path() {
    target_path="$1"
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "import os, sys; print(os.path.abspath(os.path.realpath(sys.argv[1])))" "$target_path" 2>/dev/null
    elif command -v python >/dev/null 2>&1; then
        python -c "import os, sys; print(os.path.abspath(os.path.realpath(sys.argv[1])))" "$target_path" 2>/dev/null
    elif [ -d "$target_path" ]; then
        (cd "$target_path" && pwd -P)
    else
        echo "$target_path"
    fi
}

# ==========================================================================
## Color output setup
# ==========================================================================
if command -v tput >/dev/null 2>&1; then
    COLORS=$(tput colors 2>/dev/null || echo 0)
else
    COLORS=0
fi

if [ "$COLORS" -gt 2 ]; then
    # Generate literal ESC byte portably in POSIX sh
    ESC=$(printf '\033')

    COLOR_OK="${ESC}[1;97m${ESC}[42m"
    COLOR_ERR="${ESC}[1;93m${ESC}[6;101m"
    COLOR_OFF="${ESC}[0m"

    prefix="${COLOR_OK}${prefix}${COLOR_OFF}"
    prefix_error="${COLOR_ERR}${prefix_error}${COLOR_OFF}"
fi

printf "%s LCG version=%s PLATFORM=%s\n" "${prefix}" "${LCG}" "${PLATFORM}"

# ================================================================================
## Wake up the cvmfs fuse mount (on Windows WSL or dormant CVMFS mounts)
# ================================================================================
run=1
while [ "$run" -le 50 ]; do

    for the_dir in \
        /cvmfs/sft.cern.ch/ \
        /cvmfs/sft.cern.ch/lcg \
        /cvmfs/sft.cern.ch/lcg/views \
        /cvmfs/sft-nightlies.cern.ch \
        /cvmfs/sft-nightlies.cern.ch/lcg \
        /cvmfs/sft-nightlies.cern.ch/lcg/views \
        "/cvmfs/sft.cern.ch/lcg/views/${LCG}" \
        "/cvmfs/sft.cern.ch/lcg/views/${LCG}/${PLATFORM}"
    do
        if [ ! -d "$the_dir" ]; then
            ( ( ls -al "$the_dir" >/dev/null 2>&1 ) ;
              ( cd "$the_dir" >/dev/null 2>&1 && ls -al . >/dev/null 2>&1 ) ;
              ( ls -al "$the_dir" >/dev/null 2>&1 ) )
        fi
    done 

    for the_file in \
        /cvmfs/sft.cern.ch/lcg/views/setupViews.sh \
        /cvmfs/sft.cern.ch/lcg/views/setupViews.csh
    do
        ( ( ls -al "$the_file" >/dev/null 2>&1 ) ;
          ( cat    "$the_file" >/dev/null 2>&1 ) ; 
          ( ls -al "$the_file" >/dev/null 2>&1 ) )
    done

    ( ( ls -al "/cvmfs/sft.cern.ch/lcg/views/${LCG}/${PLATFORM}/setup.sh" > /dev/null 2>&1 ) ;
      ( cat    "/cvmfs/sft.cern.ch/lcg/views/${LCG}/${PLATFORM}/setup.sh" > /dev/null 2>&1 ) ;
      ( ls -al "/cvmfs/sft.cern.ch/lcg/views/${LCG}/${PLATFORM}/setup.sh" > /dev/null 2>&1 ) )

    if [ -d /cvmfs/sft.cern.ch ] && \
       [ -d /cvmfs/sft.cern.ch/lcg ] && \
       [ -d /cvmfs/sft.cern.ch/lcg/views ] && \
       [ -d /cvmfs/sft-nightlies.cern.ch ] && \
       [ -d /cvmfs/sft-nightlies.cern.ch/lcg ] && \
       [ -d /cvmfs/sft-nightlies.cern.ch/lcg/views ] && \
       [ -f /cvmfs/sft.cern.ch/lcg/views/setupViews.sh ] && \
       [ -f /cvmfs/sft.cern.ch/lcg/views/setupViews.csh ]; then
        break
    else
        printf "%s Make a try to wake up cvmfs #%s\n" "${prefix}" "${run}"
        sleep 2
    fi
    run=$((run + 1))
done

( ls -al /cvmfs/sft.cern.ch/lcg/releases/binutils/ >/dev/null 2>&1 )

if [ -n "${LCG}" ] && [ -d "/cvmfs/sft.cern.ch/lcg/views/${LCG}" ]; then
    :
else
    printf "%s Valid LCGs are: %s\n" "${prefix_error}" "$(ls /cvmfs/sft.cern.ch/lcg/views 2>/dev/null)"
    safe_exit 110
fi

if [ -n "${PLATFORM}" ] && [ -d "/cvmfs/sft.cern.ch/lcg/views/${LCG}/${PLATFORM}" ]; then
    :
else
    printf "%s Valid platforms are: %s\n" "${prefix_error}" "$(ls "/cvmfs/sft.cern.ch/lcg/views/${LCG}" 2>/dev/null)"
    safe_exit 111
fi

LCG_VIEWS="/cvmfs/sft.cern.ch/lcg/views"
LCG_BUILD="${LCG_VIEWS}/${LCG}/${PLATFORM}"
LCG_SETUP="${LCG_BUILD}/setup.sh"

LCG_BUILD=$(get_canonical_path "${LCG_BUILD}")
LCG_SETUP=$(get_canonical_path "${LCG_SETUP}")

if [ -n "${LCG}" ] && [ -n "${PLATFORM}" ] && \
   [ -d "${LCG_VIEWS}" ] && [ -d "${LCG_BUILD}" ] && \
   [ -f "${LCG_SETUP}" ] && [ -r "${LCG_SETUP}" ]; then

    printf "%s Source LCG setup   = %s\n" "${prefix}" "${LCG_SETUP}"
    . "${LCG_SETUP}"
else
    printf "%s No valid LCG/PLATFORM/setup script: %s\n" "${prefix_error}" "${LCG_SETUP}"
    safe_exit 112 
fi

## CLANG wrapper check
case "${LCG_BUILD}" in
    *"x86_64-el9-clang22-"*)
        wrapper="/cvmfs/sft.cern.ch/lcg/contrib/clang/22.1.5/x86_64-el9/setup-wrapper.sh"
        if [ -f "${wrapper}" ] && [ -r "${wrapper}" ]; then 
            printf "%s Source clang22-wrapper = %s\n" "${prefix}" "${wrapper}"
            . "${wrapper}"
        fi
        ;;
esac

## Check ROOTSYS
if [ -n "${ROOTSYS}" ] && \
   [ -d "${ROOTSYS}" ] && \
   [ -d "${ROOTSYS}/bin" ] && \
   [ -x "${ROOTSYS}/bin/root" ] && \
   [ -x "${ROOTSYS}/bin/root.exe" ] && \
   [ -x "${ROOTSYS}/bin/root-config" ]; then 
    :
else 
    printf "%s No valid ROOTSYS directory: %s\n" "${prefix_error}" "${ROOTSYS}"
    safe_exit 113
fi

OSTAP_SOURCE="${3:-${OSTAP_SOURCE}}"

source_found=""
for source_dir in \
    "${OSTAP_SOURCE:-${OSTAP_HOME}}" \
    "${OSTAP_HOME:-${PWD}}" \
    "${HOME}/ostap" \
    "${PWD}" \
    "../" \
    "./"
do
    if [ -n "${source_dir}" ] && \
       [ -d "${source_dir}" ] && \
       [ -d "${source_dir}/cmake" ] && \
       [ -d "${source_dir}/data" ] && \
       [ -d "${source_dir}/docs" ] && \
       [ -d "${source_dir}/examples" ] && \
       [ -d "${source_dir}/ostap" ] && \
       [ -d "${source_dir}/scripts" ] && \
       [ -d "${source_dir}/source" ] && \
       [ -d "${source_dir}/ReleaseNotes" ] && \
       [ -d "${source_dir}/.aux" ] && \
       [ -f "${source_dir}/CMakeLists.txt" ] && \
       [ -f "${source_dir}/.aux/.build-ostap" ]; then
        source_found=$(get_canonical_path "${source_dir}")
        break 
    fi
done

if [ -n "${source_found}" ] && [ -d "${source_found}" ]; then
    OSTAP_SOURCE=$(get_canonical_path "${source_found}")
    printf "%s Use OSTAP_SOURCE   = %s\n" "${prefix}" "${OSTAP_SOURCE}"
else
    printf "%s No ostap source directory found!\n" "${prefix_error}"
    safe_exit 114 
fi

## Parameter #4: build directory
OSTAP_BUILD="${4:-${OSTAP_BUILD}}"
ostap_build_upper=$(echo "${OSTAP_BUILD}" | tr '[:lower:]' '[:upper:]')

if [ -n "${OSTAP_BUILD}" ] && [ -d "${OSTAP_BUILD}" ] && [ -w "${OSTAP_BUILD}" ]; then

    OSTAP_BUILD=$(get_canonical_path "${OSTAP_BUILD}")
    printf "%s Use OSTAP_BUILD    = %s\n" "${prefix}" "${OSTAP_BUILD}"

elif [ -n "${OSTAP_BUILD}" ] && [ "${ostap_build_upper}" = "TMP" ]; then

    OSTAP_BUILD=$(mktemp -d -t "ostap-$(date '+%Y-%b-%d')-OSTAP-BUILD-DIR-XXXXXX")
    OSTAP_BUILD=$(get_canonical_path "${OSTAP_BUILD}")
    printf "%s Build directory is created %s\n" "${prefix}" "${OSTAP_BUILD}"

elif [ -d "${OSTAP_SOURCE}/build" ] && [ -w "${OSTAP_SOURCE}/build" ]; then

    OSTAP_BUILD=$(get_canonical_path "${OSTAP_SOURCE}/build")
    printf "%s Use OSTAP_BUILD    = %s\n" "${prefix}" "${OSTAP_BUILD}"

elif [ -w "${OSTAP_SOURCE}" ] && [ ! -d "${OSTAP_SOURCE}/build" ]; then

    mkdir -p "${OSTAP_SOURCE}/build"
    OSTAP_BUILD=$(get_canonical_path "${OSTAP_SOURCE}/build")
    printf "%s Build directory is created %s\n" "${prefix}" "${OSTAP_BUILD}"

else

    OSTAP_BUILD=$(mktemp -d -t "ostap-$(date '+%Y-%b-%d')-OSTAP-BUILD-DIR-XXXXXX")
    OSTAP_BUILD=$(get_canonical_path "${OSTAP_BUILD}")
    printf "%s Build directory is created %s\n" "${prefix}" "${OSTAP_BUILD}"

fi

## Check build directory validation
if [ -n "${OSTAP_BUILD}" ] && [ -d "${OSTAP_BUILD}" ] && [ -w "${OSTAP_BUILD}" ]; then
    OSTAP_BUILD=$(get_canonical_path "${OSTAP_BUILD}")
    printf "%s Use OSTAP_BUILD    = %s\n" "${prefix}" "${OSTAP_BUILD}"
else
    printf "%s No valid build directory is found! %s\n" "${prefix_error}" "${OSTAP_BUILD}"
    safe_exit 115
fi     

## Check CMAKE & NINJA
if command -v cmake >/dev/null 2>&1; then
    printf "%s CMAKE              : %s\n" "${prefix}" "$(command -v cmake)"
    printf "%s CMAKE version      : %s\n" "${prefix}" "$(cmake --version | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+')"
else
    printf "%s CMAKE is not found!\n" "${prefix_error}"
    safe_exit 116
fi

if command -v ctest >/dev/null 2>&1; then
    printf "%s CTEST              : %s\n" "${prefix}" "$(command -v ctest)"
    printf "%s CTEST version      : %s\n" "${prefix}" "$(ctest --version | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+')"
else
    printf "%s CTEST is not found!\n" "${prefix_error}"
    safe_exit 117 
fi

if command -v cpack >/dev/null 2>&1; then
    printf "%s CPACK              : %s\n" "${prefix}" "$(command -v cpack)"
    printf "%s CPACK version      : %s\n" "${prefix}" "$(cpack --version | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+')"
else
    printf "%s CPACK is not found!\n" "${prefix_error}"
    safe_exit 118 
fi

if command -v ninja >/dev/null 2>&1; then
    printf "%s NINJA              : %s\n" "${prefix}" "$(command -v ninja)"
    printf "%s NINJA version      : %s\n" "${prefix}" "$(ninja --version | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+')"
else
    printf "%s NINJA is not found!\n" "${prefix_error}"
    safe_exit 119 
fi 

if [ -f "${OSTAP_BUILD}/build.ninja" ]; then
    if command -v ninja >/dev/null 2>&1; then
        printf "%s Clean  OSTAP_BUILD   build remnants   %s\n" "${prefix}" "${OSTAP_BUILD}"
        ( cd "${OSTAP_BUILD}" && ninja clean )
    fi
fi

printf "%s Remove OSTAP_BUILD   remnants&garbage %s\n" "${prefix}" "${OSTAP_BUILD}"
( cd "${OSTAP_BUILD}" && \
  rm -rf -- CM* CP* CT* *nin* scripts/ source/ ostap/ examples/ Testing/ Ma* .nin* Dart* cmake* instal* packages Tes* *.py~ *.C~ __* _CPack* \#* *~ .*~ .\#* )

## Parameter #5: install directory 
OSTAP_INSTALL="${5:-${OSTAP_INSTALL}}"

if [ -n "${OSTAP_INSTALL}" ] && [ -d "${OSTAP_INSTALL}" ] && [ -w "${OSTAP_INSTALL}" ]; then

    OSTAP_INSTALL=$(get_canonical_path "${OSTAP_INSTALL}")
    printf "%s Clean  OSTAP_INSTALL directory        %s\n" "${prefix}" "${OSTAP_INSTALL}"
    ( cd "${OSTAP_INSTALL}" && \
      rm -rf -- .footprints .ostap.build .ostaprc .rootlogon.C cmake examples include lib packages scripts thisostap.sh )

elif [ -n "${OSTAP_INSTALL}" ] && [ -d "${OSTAP_INSTALL}" ] && [ ! -w "${OSTAP_INSTALL}" ]; then

    printf "%s Directory OSTAP_INSTALL is not writeable! %s\n" "${prefix_error}" "${OSTAP_INSTALL}"
    safe_exit 120

else

    OSTAP_INSTALL="${OSTAP_BUILD}/INSTALL/${LCG}/${PLATFORM}"
    OSTAP_INSTALL=$(get_canonical_path "${OSTAP_INSTALL}")

fi

printf "%s LCG VERSION    : %s\n" "${prefix}" "${LCG}"
printf "%s LCG PLATFORM   : %s\n" "${prefix}" "${PLATFORM}"
printf "%s LCG BUILD      : %s\n" "${prefix}" "${LCG_BUILD}"

printf "%s ROOTSYS        : %s\n" "${prefix}" "${ROOTSYS}"

printf "%s OSTAP_SOURCE   : %s\n" "${prefix}" "${OSTAP_SOURCE}"
printf "%s OSTAP_INSTALL  : %s\n" "${prefix}" "${OSTAP_INSTALL}"
printf "%s OSTAP_BUILD    : %s\n" "${prefix}" "${OSTAP_BUILD}"

old_prefix="${prefix}"
old_prefix_error="${prefix_error}"

# =======================================================================================
## Actual build script sourcing
# =======================================================================================
if [ -f "${OSTAP_SOURCE}/.aux/.build-ostap" ] && [ -r "${OSTAP_SOURCE}/.aux/.build-ostap" ]; then
    . "${OSTAP_SOURCE}/.aux/.build-ostap" "${OSTAP_SOURCE}" "${OSTAP_INSTALL}" "${OSTAP_BUILD}"
    result=$?
else
    printf "%s Build script not found: %s/.aux/.build-ostap\n" "${prefix_error}" "${OSTAP_SOURCE}"
    result=121
fi

prefix="${old_prefix}"
prefix_error="${old_prefix_error}"

printf "%s LCG VERSION    : %s\n" "${prefix}" "${LCG}"
printf "%s LCG PLATFORM   : %s\n" "${prefix}" "${PLATFORM}"
printf "%s LCG BUILD      : %s\n" "${prefix}" "${LCG_BUILD}"

if [ "$result" -eq 0 ]; then
    printf "%s RESULT         : SUCCESS\n" "${prefix}"
else
    printf "%s RESULT         : %s\n" "${prefix_error}" "${result}"
fi

# ===================================================================================
safe_exit "${result}"

# ===================================================================================
##                                                                            The END 
# ===================================================================================

