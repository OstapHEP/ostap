#!/bin/sh
# =====================================================================
# @file
# Helper script to define the environment for ostap-@OSTAP_VERSION@ sh/bash/ksh/zsh 
# =====================================================================

if [ -n "${PYTHONNOUSERSITE}" ]; then
    printf 'thisostap.sh: unset PYTHONNOUSERSITE %s\n' "${PYTHONNOUSERSITE}"
    unset PYTHONNOUSERSITE
fi

## Helper functions for PATH manipulation via Python
_path_prepend() {
cat <<EOF | python - "$1" "$2"
import os, sys
path = sys.argv[1] 
item = sys.argv[2] if 2 < len(sys.argv) else ''
item = item.strip() 
path = os.environ.get(path, '')
path = path.split(os.pathsep) 
if item: path.insert(0, item) 
npath = []
for p in path: 
    if not os.path.exists(p): continue 
    if not os.path.isdir(p): continue 
    pn = os.path.normpath(p) 
    if pn in npath: continue 
    npath.append(pn)
path = os.pathsep.join(npath)
print(path)
EOF
}

_path_remove() {
cat <<EOF | python - "$1" "$2"
import os, sys
path = sys.argv[1] 
item = sys.argv[2] if 2 < len(sys.argv) else ''
item = item.strip() 
path = os.environ.get(path, '')
path = path.split(os.pathsep) 
npath = []
for p in path: 
    if os.path.exists(item) and os.path.samefile(p, item): continue     
    if not os.path.exists(p): continue 
    if not os.path.isdir(p): continue 
    pn = os.path.normpath(p) 
    if pn in npath: continue 
    npath.append(pn)
path = os.pathsep.join(npath)
print(path)
EOF
}

# =============================================================================
## Clean old OSTAP paths if OSTAP_DIR was previously set
# =============================================================================
if [ -n "${OSTAP_DIR}" ] && [ -d "${OSTAP_DIR}" ]; then
    old_ostap_dir="${OSTAP_DIR}"
    PATH=$(_path_remove PATH "${old_ostap_dir}/bin"); export PATH
    PYTHONPATH=$(_path_remove PYTHONPATH "${old_ostap_dir}"); export PYTHONPATH
    PYTHONPATH=$(_path_remove PYTHONPATH "${old_ostap_dir}@OSTAP_PYTHON_SITE_DIR@"); export PYTHONPATH
    LD_LIBRARY_PATH=$(_path_remove LD_LIBRARY_PATH "${old_ostap_dir}/lib"); export LD_LIBRARY_PATH
    MANPATH=$(_path_remove MANPATH "${old_ostap_dir}/doc/man"); export MANPATH
fi

# =============================================================================
## Determine SCRIPT_PATH portably depending on shell (bash/zsh/ksh/sh)
# =============================================================================
if [ -n "${BASH_SOURCE-}" ]; then
    SCRIPT_PATH="${BASH_SOURCE[0]}"
elif [ -n "${ZSH_VERSION-}" ]; then
    eval 'SCRIPT_PATH="${(%):-%x}"'
elif [ -n "${.sh.file-}" ]; then
    SCRIPT_PATH="${.sh.file}"
else
    SCRIPT_PATH="$0"
fi

# =============================================================================
## Resolve symlinks on the script file itself to get actual OSTAP_DIR
# =============================================================================
THIS_SCRIPT="${SCRIPT_PATH}"

while [ -h "${THIS_SCRIPT}" ]; do
    DIR="$(cd -P "$(dirname "${THIS_SCRIPT}")" >/dev/null 2>&1 && pwd)"
    THIS_SCRIPT="$(readlink "${THIS_SCRIPT}")"
    case "${THIS_SCRIPT}" in
        /*) ;;
        *) THIS_SCRIPT="${DIR}/${THIS_SCRIPT}" ;;
    esac 
done

OSTAP_DIR="$(cd -P "$(dirname "${THIS_SCRIPT}")" >/dev/null 2>&1 && pwd)"
export OSTAP_DIR 

OSTAP_VERSION=@OSTAP_VERSION@
export OSTAP_VERSION

# =============================================================================
## Update environment paths
# =============================================================================
PATH=$(_path_prepend PATH "${OSTAP_DIR}/bin"); export PATH

if [ -d "${OSTAP_DIR}@OSTAP_PYTHON_SITE_DIR@" ]; then
    PYTHONPATH=$(_path_prepend PYTHONPATH "${OSTAP_DIR}@OSTAP_PYTHON_SITE_DIR@")
    export PYTHONPATH
else
    PYTHONPATH=$(_path_prepend PYTHONPATH "${OSTAP_DIR}")
    export PYTHONPATH
fi

LD_LIBRARY_PATH=$(_path_prepend LD_LIBRARY_PATH "${OSTAP_DIR}/lib"); export LD_LIBRARY_PATH
MANPATH=$(_path_prepend MANPATH "${OSTAP_DIR}/doc/man"); export MANPATH

# Clean up helper shell functions
unset -f _path_prepend
unset -f _path_remove 
unset THIS_SCRIPT SCRIPT_PATH DIR old_ostap_dir

# =====================================================================
#                                                               The END 
# =====================================================================
