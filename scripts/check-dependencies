from   ostap.core.meta_info   import root_info, python_info, ostap_info 
from   ostap.logger.colorized import attention
from   ostap.logger.logger    import getLogger
import sys, subprocess, importlib 
# =============================================================================
logger = getLogger('ostap-check-dependencies')
# =============================================================================
##  check & install packages via pip 
def check_install ( *packages ) :
    """ Check & install packages via pip
    """
    missing = []
    # =========================================================================
    for package in packages :
        # =====================================================================
        try : # ===============================================================
            # =================================================================
            importlib.import_module( package )
            # =================================================================
        except ImportError : # ================================================
            # =================================================================            
            missing.append ( package )

    # =========================================================================
    ## It is OK ? 
    if not missing : return

    ## Use pip to install missing packages 
    logger.info ( 'Use pip to install  [%s]' %  ( ','.join ( missing ) ) ) 
    subprocess.run ( [ sys.executable , "-m" ,  "pip" , "install" , "--user" ] + missing  )

    ## re-check and report the problmes 
    missing = []
    for package in packages :
        # =====================================================================
        try : # ===============================================================
            # =================================================================
            importlib.import_module( package )
            # =================================================================
        except ImportError : # ================================================
            # =================================================================
            missing.append ( package )

    ## report 
    if missing :
        logger.info ( 'Failed to (pip)install [%s]' %  ( ','.join ( missing ) ) ) 

# =============================================================================
